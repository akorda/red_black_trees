{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/src/RedBlackTrees.slnx", "/property:GenerateFullPaths=true", "/consoleloggerparameters:NoSummary"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "generate_pdf",
      "command": "pdflatex",
      "type": "process",
      "args": ["red_black_trees.tex"],
      "options": {
        "cwd": "${workspaceFolder}/docs/paper/"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
